# ===========================
# Frontend API Configuration
# ===========================

# Local development (backend running on your machine)
REACT_APP_API_URL=http://localhost:5000

# Production (set this in the Render dashboard to your backend's Render URL)
# Example: https://cricsearch-backend.onrender.com
# REACT_APP_API_URL=https://cricsearch-backend.onrender.com

# ===========================
# Cloudinary Configuration
# ===========================
# Your Cloudinary cloud name (found in your Cloudinary dashboard)
# REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
