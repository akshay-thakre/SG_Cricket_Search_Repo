# ===========================
# Backend Server Configuration
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# CORS Configuration
# ===========================
# In production, set this to your frontend Render URL (comma-separated for multiple)
# Example: https://cricsearch-frontend.onrender.com
# Leave blank to allow all origins (fine for a public read-only API)
ALLOWED_ORIGIN=

# ===========================
# Scraper Configuration
# ===========================
# Set to "true" to enable verbose scraper debug logs (disable in production)
DEBUG_SCRAPER=false

# ===========================
# Local Development / Testing
# ===========================
# Set MOCK_MODE=true to return pre-built player data without hitting SCA.
# Useful when SCA is unreachable or for offline development.
# Search returns Kintul Mistry results; stats return realistic career numbers.
# NEVER set this in production.
MOCK_MODE=false
