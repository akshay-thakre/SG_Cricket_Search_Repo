# ===========================
# Backend Server Configuration
# ===========================
PORT=5000
NODE_ENV=development

# ===========================
# CORS Configuration
# ===========================
# In production, set this to your frontend Render URL (comma-separated for multiple)
# Example: https://cricsearch-frontend.onrender.com
# Leave blank to allow all origins (fine for a public read-only API)
ALLOWED_ORIGIN=

# ===========================
# Scraper Configuration
# ===========================
# Set to "true" to enable verbose scraper debug logs (disable in production)
DEBUG_SCRAPER=false

# ===========================
# Sportygo Configuration
# ===========================
# Sportygo org ID on CricClubs — found in any player profile URL as clubId=4263.
# Defaults to 4263 in code; override here only if it ever changes.
SPORTYGO_CLUB_ID=4263

# ===========================
# Local Development / Testing
# ===========================
# MOCK_MODE — optional, set only in your local untracked .env file, never here.
# MOCK_MODE=
